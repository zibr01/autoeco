generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  phone         String?
  city          String?
  image         String?
  role          String    @default("USER") // USER | BUSINESS | MODERATOR | ADMIN
  subscription  String    @default("FREE") // FREE | PREMIUM
  referralCode  String?   @unique // уникальный код приглашения
  referredById  String?   // кто пригласил
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  referredBy       User?    @relation("Referrals", fields: [referredById], references: [id])
  referrals        User[]   @relation("Referrals")
  cars             Car[]
  bookings         Booking[]
  reviews          Review[]
  favorites        Favorite[]
  accounts         Account[]
  sessions         Session[]
  serviceCenters   ServiceCenter[] @relation("ServiceCenterOwner")
  orders           Order[]
  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")
  notifications    Notification[]
  feedbacks        Feedback[]
  ecoPoints        EcoPointsTransaction[]
  ecoPointsBalance Int        @default(0)
  ecoLevel         String     @default("bronze") // bronze, silver, gold, platinum
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Cars ─────────────────────────────────────────

model Car {
  id           String  @id @default(cuid())
  userId       String
  make         String
  model        String
  year         Int
  vin          String  @unique
  mileage      Int
  color        String
  engine       String
  transmission String
  fuelType     String
  health       Int
  image        String
  licensePlate String
  nextService  String

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  maintenanceRecords MaintenanceRecord[]
  reminders          Reminder[]
  bookings           Booking[]
  documents          CarDocument[]
  expenses           Expense[]
  installedParts     InstalledPart[]

  @@index([userId])
}

model CarDocument {
  id          String    @id @default(cuid())
  carId       String
  type        String    // osago, kasko, sts, pts, inspection, license, other
  title       String
  number      String?
  issueDate   DateTime?
  expiryDate  DateTime?
  insurer     String?   // страховая компания
  cost        Float?
  notes       String?
  createdAt   DateTime  @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  carId       String
  date        DateTime
  mileage     Int
  type        String
  description String
  cost        Float
  serviceName String

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model Reminder {
  id          String    @id @default(cuid())
  carId       String
  type        String    // oil, tires, insurance, inspection, battery, brakes
  title       String
  dueDate     DateTime?
  dueMileage  Int?
  urgency     String    // low, medium, high
  description String

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

// ─── Expenses (расходы на авто) ──────────────────

model Expense {
  id          String   @id @default(cuid())
  carId       String
  category    String   // fuel, maintenance, wash, fines, parking, insurance, parts, other
  amount      Float
  date        DateTime
  description String?
  mileage     Int?
  createdAt   DateTime @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
  @@index([carId, date])
}

// ─── Installed Parts (установленные запчасти) ────

model InstalledPart {
  id              String    @id @default(cuid())
  carId           String
  name            String
  partNumber      String?   // артикул
  brand           String?
  price           Float?
  installDate     DateTime
  installMileage  Int?
  purchasePlace   String?   // где купил
  warrantyMonths  Int?      // гарантия в месяцах
  notes           String?
  createdAt       DateTime  @default(now())

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)
}

// ─── Services ─────────────────────────────────────

model ServiceCenter {
  id          String  @id @default(cuid())
  ownerId     String?
  name        String
  type        String  // sto, wash, tires, detailing, master, electric
  typeName    String
  rating      Float
  reviewCount Int
  address     String
  district    String
  city        String
  phone       String
  hours       String
  image       String
  tags        String  // JSON array stored as string
  description String
  priceFrom   Int
  verified    Boolean @default(false)
  featured    Boolean @default(false)
  services    String  // JSON array stored as string
  photos      String  // JSON array stored as string
  lat         Float?
  lng         Float?
  clubDiscount Int       @default(20)

  owner      User?       @relation("ServiceCenterOwner", fields: [ownerId], references: [id])
  priceList  PriceItem[]
  reviews    Review[]
  timeSlots  TimeSlot[]
  bookings   Booking[]
  favorites  Favorite[]
  promoCodes PromoCode[]
}

model PriceItem {
  id              String @id @default(cuid())
  serviceCenterId String
  name            String
  price           String

  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)
}

model Review {
  id              String   @id @default(cuid())
  serviceCenterId String
  userId          String?
  author          String
  avatar          String
  rating          Int
  date            DateTime
  text            String
  carModel        String

  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id])
  reply         ReviewReply?

  @@index([serviceCenterId])
}

model ReviewReply {
  id        String   @id @default(cuid())
  reviewId  String   @unique
  text      String
  createdAt DateTime @default(now())

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
}

model TimeSlot {
  id              String  @id @default(cuid())
  serviceCenterId String
  time            String
  available       Boolean

  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)
}

// ─── Parts ────────────────────────────────────────

model Part {
  id             String  @id @default(cuid())
  name           String
  category       String
  compatibleCars String  // JSON array stored as string
  description    String
  image          String?

  offers PartOffer[]
}

model PartOffer {
  id           String  @id @default(cuid())
  partId       String
  seller       String
  sellerLogo   String
  brand        String
  type         String  // original, oem, analog
  typeName     String
  price        Int
  deliveryDays Int
  inStock      Boolean
  warranty     String
  partNumber   String
  rating       Float?

  part       Part        @relation(fields: [partId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

// ─── Favorites ───────────────────────────────────

model Favorite {
  id              String   @id @default(cuid())
  userId          String
  serviceCenterId String
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceCenterId])
}

// ─── Promo Codes ─────────────────────────────────

model PromoCode {
  id              String    @id @default(cuid())
  serviceCenterId String
  code            String
  description     String
  discountPercent Int
  maxUses         Int       @default(100)
  usedCount       Int       @default(0)
  active          Boolean   @default(true)
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())

  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)

  @@unique([serviceCenterId, code])
}

// ─── Bookings ─────────────────────────────────────

model Booking {
  id              String   @id @default(cuid())
  userId          String
  serviceCenterId String
  carId           String
  serviceType     String
  date            DateTime
  time            String
  status          String   @default("pending") // pending, confirmed, completed, cancelled
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)
  car           Car           @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([serviceCenterId])
  @@index([serviceCenterId, createdAt])
}

// ─── Orders (parts) ─────────────────────────────────

model Order {
  id          String   @id @default(cuid())
  userId      String
  status      String   @default("pending") // pending, confirmed, shipped, delivered, cancelled
  totalPrice  Int
  name        String
  phone       String
  email       String
  address     String
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([userId])
}

model OrderItem {
  id          String @id @default(cuid())
  orderId     String
  partOfferId String
  partName    String
  seller      String
  brand       String
  partNumber  String
  price       Int
  quantity    Int

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  partOffer PartOffer @relation(fields: [partOfferId], references: [id])
}

// ─── Messages (service chat) ─────────────────────────

model Message {
  id              String   @id @default(cuid())
  senderId        String
  receiverId      String
  serviceCenterId String?
  bookingId       String?
  text            String
  read            Boolean  @default(false)
  createdAt       DateTime @default(now())

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([senderId, receiverId])
}

// ─── Notifications ──────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // booking_created, booking_confirmed, booking_cancelled, review_reply, reminder_due, system
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
}

// ─── Feedback (обратная связь) ───────────────────

model Feedback {
  id          String   @id @default(cuid())
  userId      String?
  userName    String   @default("Аноним")
  userEmail   String?
  page        String   // URL-страница, откуда отправлено
  message     String
  status      String   @default("new")     // new, in_progress, not_important, fixed
  priority    String   @default("monthly") // urgent, monthly, future
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([priority])
  @@index([page])
  @@index([createdAt])
}

// ─── EcoPoints (Loyalty) ────────────────────────

model EcoPointsTransaction {
  id          String   @id @default(cuid())
  userId      String
  amount      Int      // positive = earned, negative = spent
  type        String   // booking, review, referral, daily_login, car_added, maintenance, promo, spent
  description String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
