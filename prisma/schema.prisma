generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  passwordHash  String?
  phone         String?
  city          String?
  image         String?
  role          String    @default("USER") // USER | BUSINESS
  subscription  String    @default("FREE") // FREE | PREMIUM
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  cars           Car[]
  bookings       Booking[]
  reviews        Review[]
  accounts       Account[]
  sessions       Session[]
  serviceCenters ServiceCenter[] @relation("ServiceCenterOwner")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Cars ─────────────────────────────────────────

model Car {
  id           String  @id @default(cuid())
  userId       String
  make         String
  model        String
  year         Int
  vin          String  @unique
  mileage      Int
  color        String
  engine       String
  transmission String
  fuelType     String
  health       Int
  image        String
  licensePlate String
  nextService  String

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  maintenanceRecords MaintenanceRecord[]
  reminders          Reminder[]
  bookings           Booking[]
}

model MaintenanceRecord {
  id          String   @id @default(cuid())
  carId       String
  date        DateTime
  mileage     Int
  type        String
  description String
  cost        Float
  serviceName String

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model Reminder {
  id          String    @id @default(cuid())
  carId       String
  type        String    // oil, tires, insurance, inspection, battery, brakes
  title       String
  dueDate     DateTime?
  dueMileage  Int?
  urgency     String    // low, medium, high
  description String

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)
}

// ─── Services ─────────────────────────────────────

model ServiceCenter {
  id          String  @id @default(cuid())
  ownerId     String?
  name        String
  type        String  // sto, wash, tires, detailing, master, electric
  typeName    String
  rating      Float
  reviewCount Int
  address     String
  district    String
  city        String
  phone       String
  hours       String
  image       String
  tags        String  // JSON array stored as string
  description String
  priceFrom   Int
  verified    Boolean @default(false)
  featured    Boolean @default(false)
  services    String  // JSON array stored as string
  photos      String  // JSON array stored as string

  owner     User?       @relation("ServiceCenterOwner", fields: [ownerId], references: [id])
  priceList PriceItem[]
  reviews   Review[]
  timeSlots TimeSlot[]
  bookings  Booking[]
}

model PriceItem {
  id              String @id @default(cuid())
  serviceCenterId String
  name            String
  price           String

  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)
}

model Review {
  id              String   @id @default(cuid())
  serviceCenterId String
  userId          String?
  author          String
  avatar          String
  rating          Int
  date            DateTime
  text            String
  carModel        String

  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id])
}

model TimeSlot {
  id              String  @id @default(cuid())
  serviceCenterId String
  time            String
  available       Boolean

  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)
}

// ─── Parts ────────────────────────────────────────

model Part {
  id             String  @id @default(cuid())
  name           String
  category       String
  compatibleCars String  // JSON array stored as string
  description    String
  image          String?

  offers PartOffer[]
}

model PartOffer {
  id           String  @id @default(cuid())
  partId       String
  seller       String
  sellerLogo   String
  brand        String
  type         String  // original, oem, analog
  typeName     String
  price        Int
  deliveryDays Int
  inStock      Boolean
  warranty     String
  partNumber   String
  rating       Float?

  part Part @relation(fields: [partId], references: [id], onDelete: Cascade)
}

// ─── Bookings ─────────────────────────────────────

model Booking {
  id              String   @id @default(cuid())
  userId          String
  serviceCenterId String
  carId           String
  serviceType     String
  date            DateTime
  time            String
  status          String   @default("pending") // pending, confirmed, completed, cancelled
  createdAt       DateTime @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceCenter ServiceCenter @relation(fields: [serviceCenterId], references: [id], onDelete: Cascade)
  car           Car           @relation(fields: [carId], references: [id], onDelete: Cascade)
}
